# ─────────────────────────────────────────────────────────────────
# Eco Start AI — Environment Variables
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
# Every variable below has a working local-dev default except where
# noted. Nothing here is a real secret.
# ─────────────────────────────────────────────────────────────────

# ---- Database -------------------------------------------------
# Two connection strings, on purpose (principle of least privilege):
#
# DATABASE_URL     — used ONLY by `npm run db:migrate` / `npm run db:seed`.
#                     Owns the schema, so it needs elevated privileges.
# APP_DATABASE_URL — used by the running Next.js app for every request.
#                     Connects as `app_user`, a role with no special
#                     privileges, so Postgres Row Level Security
#                     (src/db/migrations/0002_rls.sql) actually applies.
#
# Local values match docker-compose.yml exactly — no setup needed.
# Production: point both at your Supabase Postgres project (see
# docs/DEPLOYMENT.md for the exact connection strings to use).
DATABASE_URL="postgres://ecostart:ecostart_dev_password@localhost:5434/eco_start_ai"
APP_DATABASE_URL="postgres://app_user:app_user_dev_password@localhost:5434/eco_start_ai"

# ---- Sessions / Auth --------------------------------------------
# Generate with: openssl rand -base64 32
# A working local default is provided so the app boots out of the
# box — replace it before deploying anywhere real.
SESSION_SECRET="dev-only-session-secret-change-me-before-deploying-please"

# Shared local password for every seeded demo account (see docs/DEMO-SCENARIO.md).
DEMO_ACCOUNT_PASSWORD="EcoStart2026!"

# ---- App -----------------------------------------------------------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="kk"

# ---- AI Providers (all optional — the app auto-falls back to the
# deterministic mock provider when a key is missing, and shows a
# "Development Mode" badge in the UI when it does) -----------------

# 1st priority — Google Gemini (text + vision)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# 2nd priority — Cloudflare Workers AI
# https://dash.cloudflare.com/?to=/:account/ai/workers-ai
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_AI_API_TOKEN=""

# 3rd priority — OpenRouter (model-agnostic fallback)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct:free"

# Force a specific provider regardless of what keys are present.
# One of: gemini | cloudflare | openrouter | mock. Leave empty for
# automatic priority-based selection.
AI_PROVIDER_OVERRIDE=""

# ---- Storage (media uploads) --------------------------------------
# Local dev: files are written under /public/uploads (no setup needed).
# Production: set the R2 variables below to switch the storage
# adapter automatically — see docs/DEPLOYMENT.md.
STORAGE_DRIVER="local" # local | r2

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="eco-start-ai-media"
R2_PUBLIC_URL=""

# ---- Supabase (production auth/DB host — optional locally) --------
# Only needed if you point DATABASE_URL at a hosted Supabase project
# instead of the local Docker database. See docs/DEPLOYMENT.md.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Rate limiting -------------------------------------------------
AI_CHAT_RATE_LIMIT_PER_MINUTE="8"
AI_GENERATION_RATE_LIMIT_PER_HOUR="30"
LOGIN_RATE_LIMIT_ATTEMPTS="30"
LOGIN_RATE_LIMIT_WINDOW_MINUTES="5"
